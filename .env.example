VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend API (MongoDB/Express)
VITE_API_BASE_URL=http://localhost:5000
VITE_SITE_URL=http://localhost:5173

# Site metadata for SEO
VITE_SITE_NAME=Nelna Farm
VITE_SITE_LOCALE=en_LK

# Backend runtime and security
PORT=5000
CORS_ORIGIN_ALLOWLIST=http://localhost:5173,http://localhost:5174
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# Optional: Cloud Function endpoint for email notifications
VITE_FUNCTIONS_BASE_URL=https://<region>-<project>.cloudfunctions.net

# Optional: Google PageSpeed Insights API key (backend)
PAGESPEED_API_KEY=
